:: StoryStylesheet [stylesheet]
tw-sidebar{ 
 display: none; 
}

.options{
  display: flex;
  flex-direction: column;
}

.terminal_response{
  color: #f9f1a5;
  font-family: "Cascadia Code";
}

.terminal{
  color: #6af549;
  font-family: "Cascadia Code";
}

tw-link{ 
  padding: 10px;
  border: solid 2px grey;
  border-radius: 10px;
  color: grey;
}
  
#instructions{
  background-color: #111111;
  width: 500px;
  height: auto;
  border-radius: 10px;
  border: solid white 2px;
  color: white;
  text-align: center; 
  padding: 10px;
}